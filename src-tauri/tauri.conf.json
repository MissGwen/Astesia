{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Astesia",
  "version": "0.1.0",
  "identifier": "com.astesia.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Astesia - Database Manager",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ChingCdesu/Astesia/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU0RkQzOTgxMDEzM0NCOUIKUldTYnl6TUJnVG45NUZQNWY5U2tHOFdXMVJqOSt4VkozU0kxRGg5OHVXV1hnVUFuOUM2bmlOcncK"
    }
  }
}
